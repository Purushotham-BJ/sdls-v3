# Copy to .env and fill in values for your deployment.

# EC2 multi-host example:
#   System 3 (infra) node — run system3-compose.yml
REDIS_HOST=10.0.1.10     # System 3 private IP (also used by Sys1/Sys2)
REDIS_PORT=6379

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_strong_password
SECRET_KEY=CHANGE_ME_32_random_alphanumeric_chars

SYSTEM_ROLE=system3       # one of: system1 | system2 | system3 | single
SYSTEM_IP=10.0.1.10       # this instance's private IP (auto-detected if blank)
